# Frontend → backend base URL (build/serve time). On a VPS set to the public host.
VITE_API_BASE=http://127.0.0.1:6952

# db-server
DB_SERVER_PORT=6952
DB_FILE=local.db

# Agent runner
CLAUDE_BIN=claude
CLAUDE_FLAGS=--dangerously-skip-permissions
