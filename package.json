{
  "name": "@airtajal/piranha",
  "private": true,
  "license": "UNLICENSED",
  "version": "0.1.0",
  "description": "Piranha — a swarm of AI agents that plan, build, and QA your backlog in isolated git worktrees, with a human-approved merge gate.",
  "type": "module",
  "bin": {
    "piranha": "bin/cli.mjs",
    "ai-agents": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "db/**/*.ts",
    "scripts/**/*.ts",
    "agentic/**/*.ts",
    "src/**",
    "index.html",
    "*.config.ts",
    "*.config.js",
    "tsconfig.json",
    ".env.example"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Airtajal/ai-agents.git"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "orchestrator",
    "multi-agent",
    "kanban",
    "automation"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node",
      "sharp",
      "protobufjs",
      "esbuild"
    ]
  },
  "scripts": {
    "predev": "kill-port 6951",
    "dev": "vite",
    "build:landing": "tsx scripts/build-landing.tsx",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:server": "cross-env DB_FILE=local.db tsx --watch db/server.ts",
    "db:orchestrator": "tsx --watch scripts/orchestrator.ts",
    "db:server:stable": "cross-env DB_FILE=local.db tsx db/server.ts",
    "db:orchestrator:stable": "tsx scripts/orchestrator.ts",
    "db:stop": "kill-port 6952",
    "ports:stop": "kill-port 6951 6952",
    "db:build": "cross-env DB_FILE=local.db tsx db/index.ts build",
    "db:context": "cross-env DB_FILE=local.db tsx db/index.ts context",
    "db:update": "cross-env DB_FILE=local.db tsx db/index.ts update",
    "db:ensure": "cross-env DB_FILE=local.db tsx db/index.ts ensure",
    "db:check": "cross-env DB_FILE=local.db tsx db/index.ts check",
    "db:search": "cross-env DB_FILE=local.db tsx db/index.ts search",
    "db:blast": "cross-env DB_FILE=local.db tsx db/index.ts blast",
    "db:stats": "cross-env DB_FILE=local.db tsx db/index.ts stats",
    "db:annotate": "cross-env DB_FILE=local.db tsx db/index.ts annotate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b && tsc --noEmit -p agentic/tsconfig.json && tsc --noEmit -p db/tsconfig.json",
    "typecheck:engine": "tsc --noEmit -p agentic/tsconfig.json && tsc --noEmit -p db/tsconfig.json",
    "agents": "kill-port 6951 6952 && concurrently --restart-tries 5 --restart-after 5000 \"pnpm exec vite\" \"pnpm:db:server:stable\" \"pnpm:db:orchestrator:stable\" --names \"vite,db,ai\" --prefix-colors \"cyan,magenta,green\"",
    "agents:vps": "set -a; [ -f .env ] && . ./.env; set +a; pnpm run agents"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@huggingface/transformers": "^4.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@typescript-eslint/typescript-estree": "^8.59.0",
    "@xyflow/react": "^12.11.2",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.469.0",
    "pg": "^8.13.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "kill-port": "^2.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
