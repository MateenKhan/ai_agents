# pnpm (>=7) does NOT run pre/post scripts by default — npm does. Without this,
# `pnpm run agents` skips `preagents` (kill-port 6951 6952) and `pnpm run dev`
# skips `predev` (kill-port 6951), so a stale db-server/vite from an earlier run
# still holds the port and the app dies with EADDRINUSE (vite has strictPort:true,
# so it hard-fails rather than hopping onto the db-server's port).
enable-pre-post-scripts=true
